# ── x402 Payment Config ────────────────────────────────────────────────────

# Your CDP wallet address (Base) — receives USDC payments from API callers
# Get this from: https://cdp.coinbase.com
X402_PAY_TO_ADDRESS=0xYOUR_WALLET_ADDRESS_HERE

# Network in CAIP-2 format (x402 v2 standard)
# Base Mainnet:    eip155:8453
# Base Sepolia:    eip155:84532
# Polygon:         eip155:137
# Arbitrum:        eip155:42161
X402_NETWORK=eip155:8453

# CDP facilitator — required for Bazaar discovery indexing
X402_FACILITATOR_URL=https://api.cdp.coinbase.com/platform/v2/x402

# ── CDP API Keys ─────────────────────────────────────────────────────────────
# Required for authenticated CDP facilitator requests (and Bazaar indexing)
# Get from: https://cdp.coinbase.com → Projects → API Keys → Create EC key
# Key type must be EC (P-256) — not legacy HMAC keys
CDP_API_KEY_ID=your-cdp-key-id-here

# Option A — paste just the base64 body from the Coinbase dashboard (code adds headers automatically):
CDP_API_KEY_SECRET=your-base64-key-body-here

# Option B — paste the full PEM on one line with literal \n for newlines:
# CDP_API_KEY_SECRET="-----BEGIN EC PRIVATE KEY-----\nYOUR_BASE64_KEY_BODY\n-----END EC PRIVATE KEY-----"

# ── Local Dev ────────────────────────────────────────────────────────────────
# Set to true to skip x402 payment checks locally (no wallet needed)
DEV_BYPASS_X402=false
